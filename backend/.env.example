DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Вариант 1: PostgreSQL через Docker (рекомендуется для ВКР) ---
# В корне проекта: docker compose up -d
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=5415
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Вариант 2: SQLite (если Postgres не настроен) ---
# DB_ENGINE=django.db.backends.sqlite3
# SQLITE_NAME=db.sqlite3

# Реквизиты продавца в документах (счёт, акт, КП)
COMPANY_NAME=ООО "Ваша Компания"
COMPANY_INN=7700000000
